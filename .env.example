# Telegram @BotFather 에서 발급받은 봇 토큰 값
TELEGRAM_BOT_TOKEN=

# Google Web Client 정보
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Google 이메일 계정 주소
GOOGLE_ACCOUNT=

# 모델 설정
# orchestrator: 모든 Google 작업 직접 처리 → 크고 똑똑한 모델 권장 (예: qwen3:32b-q4_K_M)
ORCHESTRATOR_MODEL=qwen3:32b-q4_K_M
# fallback: orchestrator 실패 시 대체 → 작고 빠른 모델 (예: qwen3:4b)
FALLBACK_MODEL=qwen3:4b
# MEMORY.md 백업 폴더 (Google Drive)
# 미설정 시 기본값: openclaw-memory
DRIVE_MEMORY_FOLDER=
