# Telegram @BotFather 에서 발급받은 봇 토큰 값
TELEGRAM_BOT_TOKEN=

# Google Web Client 정보
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Google 이메일 계정 주소
GOOGLE_ACCOUNT=

# 에이전트별 모델 설정
# orchestrator: 계획 수립·판단·종합 담당 → 크고 똑똑한 모델 권장 (예: qwen3:32b)
ORCHESTRATOR_MODEL=
# mail/calendar/drive: 각 서비스 전담 → 중간 크기 모델 권장 (예: qwen3:8b)
MAIL_MODEL=
CALENDAR_MODEL=
DRIVE_MODEL=
# fallback: 위 모델 실패 시 대체 → 작고 빠른 모델 권장 (예: qwen3:4b)
FALLBACK_MODEL=
# MEMORY.md 백업 폴더 (Google Drive)
# 미설정 시 기본값: openclaw-memory
DRIVE_MEMORY_FOLDER=
